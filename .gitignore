cat > .gitignore <<'EOF'
# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl

# Terraform state backup / variações
terraform.tfstate.backup
*.tfstate.backup

# Terragrunt
**/.terragrunt-cache/

# Chaves / credenciais (NUNCA versionar)
*.pem
*.key

# Mac / IDE
.DS_Store
.vscode/
.idea/
EOF
