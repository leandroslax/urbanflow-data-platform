cat > .gitignore <<'EOF'
# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.lock.hcl

# Terraform state backup / variações
terraform.tfstate.backup
*.tfstate.backup

# Terragrunt
**/.terragrunt-cache/

# Chaves / credenciais (NUNCA versionar)
*.pem
*.key

# Mac / IDE
.DS_Store
.vscode/
.idea/
EOF

# Default .gitignore content added by dbt Cloud# you shouldn't commit these into source control
# these are the default directory names, adjust/add to fit your needs
target/
dbt_packages/
logs/
# end dbt Cloud content
dbt_internal_packages/
*.tfstate
*.tfstate.*
